{
  "name": "emoji",
  "displayName": "Emoji Picker",
  "description": "Autocomplete emoji shortcuts that work in any file type.",
  "version": "1.0.0",
  "icon": "icon.png",
  "publisher": "akshit",

  "engines": {
    "vscode": "^1.80.0"
  },

  "categories": [
    "Other"
  ],

  "activationEvents": [
    "onLanguage"
  ],

  "main": "./extension.js",

  "contributes": {
    "commands": [
      {
        "command": "emoji.helloWorld",
        "title": "Emoji Picker: Hello World"
      }
    ]
  },

  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },

  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}